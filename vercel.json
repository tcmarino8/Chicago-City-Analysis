{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.11",
        "includeFiles": [
          "templates/**",
          "static/**",
          "data/**",
          "core/**"
        ],
        "excludeFiles": [
          "SensorsNetwork_Venv/**",
          ".venv/**",
          "venv/**",
          "cache/**",
          "notebooks/**",
          "HTML_MAPS/**",
          "%AppData%/**",
          "pages/**",
          "**/*.ipynb",
          "**/__pycache__/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}
